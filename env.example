# ─────────────────────────────────────────────────────────────────
# DocChat — Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control (it is already in .gitignore)
# ─────────────────────────────────────────────────────────────────

# ── OpenAI API ───────────────────────────────────────────────────
# Required for: LLM calls (gpt-4o-mini) + embeddings (text-embedding-3-small)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Logging ──────────────────────────────────────────────────────
# Set to DEBUG to see prompt cache hits/misses in the terminal.
# Options: DEBUG | INFO | WARNING | ERROR  (default: INFO)
LOG_LEVEL=INFO
